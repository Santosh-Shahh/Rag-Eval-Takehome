# ==============================================================================
# Environment Configuration Template
# ==============================================================================

# Gemini API Key (Required for live Gemini model execution)
GEMINI_API_KEY=

# Embedding Provider: "local" (offline, zero-cost, deterministic hashing bag-of-words) or "gemini" (online, text-embedding-004)
EMBEDDING_PROVIDER=local

# Embedding Model (if EMBEDDING_PROVIDER=local, e.g. "all-MiniLM-L6-v2", if gemini, default is text-embedding-004)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# LLM Provider: "gemini" (online, live models) or "mock" (offline fallback returning mock/echo answers)
LLM_PROVIDER=mock

# LLM Model (e.g. gemini-1.5-flash, gemini-1.5-pro, etc.)
LLM_MODEL=gemini-1.5-flash

# RAG Hyperparameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
DEFAULT_K=4
SIMILARITY_THRESHOLD=0.2
